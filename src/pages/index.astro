---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import WorkCard from '../components/WorkCard.astro';
import NewsCard from '../components/NewsCard.astro';
import { getCollection } from 'astro:content';

const works = (await getCollection('works')).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const featuredWorks = works.filter((item) => item.data.featured).slice(0, 3);
const news = (await getCollection('news')).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()).slice(0, 2);
---
<BaseLayout title="TARUKOTO Sample | Top" description="Astro minimal sample top page">
  <div class="container">
    <section class="hero">
      <div>
        <div class="kicker">Minimal Astro Sample</div>
        <h1>トップ / About / News / Works の<br />最小構成サンプル</h1>
        <p class="lead">Astro・GitHub・公開サービスを使って、まずは小さく公開まで試すためのサンプルです。CMSは使わず、News と Works は Markdown で管理します。</p>
        <a class="button" href="/works">制作実績を見る →</a>
      </div>
      <div class="panel">
        <div class="panel__visual"></div>
      </div>
    </section>

    <section class="section">
      <SectionHeading title="Featured Works" note="まずは3件だけ表示" />
      <div class="grid">
        {featuredWorks.map((work) => <WorkCard work={work} href={`/works/${work.slug}/`} />)}
      </div>
    </section>

    <section class="section">
      <SectionHeading title="Latest News" note="Markdownで追加・更新" />
      <div class="grid">
        {news.map((post) => <NewsCard post={post} href={`/news/${post.slug}/`} />)}
      </div>
    </section>
  </div>
</BaseLayout>
