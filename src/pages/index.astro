---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/ui/SectionHeading.astro";
import WorkCard from "../components/works/WorkCard.astro";
import { getCollection } from "astro:content";
import { createPageTitle, pages } from "../lib/site";

const works = (await getCollection("works")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const featuredWorks = works.filter((item) => item.data.featured).slice(0, 3);
---

<BaseLayout
  title={createPageTitle(pages.home.title)}
  description={pages.home.description}
>
  <div class="container">
    <section class="hero">
      <div>
        <div class="kicker">{pages.home.kicker}</div>
        <h1>Top / About / Works の<br />最小構成サンプル</h1>
        <p class="lead">
          Astro・GitHub・公開サービスを使って、まずは小さく公開まで試すためのサンプルです。Works は Markdown
          で管理し、トップ・About・Works の3ページ構成でまとめています。
        </p>
        <a class="button" href="/works">制作実績を見る →</a>
      </div>
      <div class="panel">
        <div class="panel__visual"></div>
      </div>
    </section>

    <section class="section">
      <SectionHeading title="About" note="わたしたちについて" />

      <div class="prose">
        <p class="lead">
          デザイン事務所として大切にしていること、 どんな相手と相性が良いか、
          どんな姿勢で制作しているかをまとめています。
        </p>

        <p>
          TARUKOTOの制作スタンスや背景については
          Aboutページで詳しく紹介しています。
        </p>

        <a class="button" href="/about"> Aboutを見る → </a>
      </div>
    </section>

    <section class="section">
      <SectionHeading title="Featured Works" note="まずは3件だけ表示" />
      <div class="grid">
        {
          featuredWorks.map((work) => (
            <WorkCard work={work} href={`/works/${work.slug}/`} />
          ))
        }
      </div>
    </section>
  </div>
</BaseLayout>
