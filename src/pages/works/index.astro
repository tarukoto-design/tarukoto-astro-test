---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeading from '../../components/ui/SectionHeading.astro';
import WorkCard from '../../components/works/WorkCard.astro';
import { getCollection } from 'astro:content';
import { createPageTitle, pages } from '../../lib/site';

const works = (await getCollection('works')).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<BaseLayout title={createPageTitle(pages.works.title)} description={pages.works.description}>
  <div class="container">
    <div class="kicker">{pages.works.kicker}</div>
    <h1>{pages.works.heading}</h1>
    <section class="section">
      <SectionHeading title={pages.works.listTitle} note={pages.works.listNote} />
      <div class="grid">
        {works.map((work) => <WorkCard work={work} href={`/works/${work.slug}/`} />)}
      </div>
    </section>
  </div>
</BaseLayout>
