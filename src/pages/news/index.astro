---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeading from '../../components/ui/SectionHeading.astro';
import { getCollection } from 'astro:content';
import { createPageTitle, pages, site } from '../../lib/site';

const posts = (await getCollection('news')).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<BaseLayout title={createPageTitle(pages.news.title)} description={pages.news.description}>
  <div class="container">
    <div class="kicker">{pages.news.kicker}</div>
    <h1>{pages.news.heading}</h1>
    <section class="section">
      <SectionHeading title={pages.news.listTitle} note={pages.news.listNote} />
      <div class="list">
        {posts.map((post) => (
          <a class="list-item" href={`/news/${post.slug}/`}>
            <div class="meta">{post.data.date.toLocaleDateString(site.locale)}</div>
            <h3>{post.data.title}</h3>
            <p>{post.data.excerpt}</p>
          </a>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
