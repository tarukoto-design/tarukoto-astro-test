---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { createPageTitle, pages, site } from '../../lib/site';

export async function getStaticPaths() {
  const posts = await getCollection('news');
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---
<BaseLayout title={createPageTitle(post.data.title)} description={post.data.excerpt}>
  <div class="container prose">
    <div class="kicker">{pages.news.kicker}</div>
    <h1>{post.data.title}</h1>
    <div class="meta">{post.data.date.toLocaleDateString(site.locale)}</div>
    <article class="prose">
      <Content />
    </article>
  </div>
</BaseLayout>
