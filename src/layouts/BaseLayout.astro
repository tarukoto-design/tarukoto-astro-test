---
import '../styles/global.css';
const { title = 'TARUKOTO Sample', description = 'Astro minimal sample site' } = Astro.props;
const path = Astro.url.pathname;
const nav = [
  { href: '/', label: 'Top' },
  { href: '/about', label: 'About' },
  { href: '/news', label: 'News' },
  { href: '/works', label: 'Works' },
];
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <header class="site-header">
      <div class="container site-header__inner">
        <a href="/" class="brand">TARUKOTO / SAMPLE</a>
        <nav class="nav">
          {nav.map((item) => (
            <a href={item.href} aria-current={path === item.href ? 'page' : undefined}>{item.label}</a>
          ))}
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container">Astro minimal sample for TARUKOTO study.</div>
    </footer>
  </body>
</html>
